<% content_for :title, "마이페이지" %>
<% content_for :noindex, true %>
<div class="min-h-screen bg-gray-50 py-12 px-4">
  <div class="max-w-4xl mx-auto">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-8 mb-6">
      <div class="flex items-start justify-between flex-wrap gap-4">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">안녕하세요, <%= @user.display_name %>님</h1>
          <p class="text-gray-500 text-sm mt-1"><%= @user.email %></p>
        </div>
        <%= button_to "로그아웃", destroy_user_session_path, method: :delete,
            class: "text-sm text-gray-600 hover:text-gray-900 underline" %>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">내 예약 내역</h2>

      <% if @reservations.any? %>
        <div class="space-y-3">
          <% @reservations.each do |reservation| %>
            <div class="border border-gray-200 rounded-xl p-4">
              <div class="flex justify-between items-start flex-wrap gap-2">
                <div>
                  <p class="font-semibold text-gray-900"><%= reservation.package_label %></p>
                  <p class="text-sm text-gray-600 mt-1"><%= l(reservation.reservation_datetime, format: :long) rescue reservation.reservation_datetime %></p>
                  <p class="text-xs text-gray-500 mt-1"><%= reservation.coaching_type %></p>
                </div>
                <span class="text-xs px-2.5 py-1 rounded-full bg-indigo-100 text-indigo-700 font-semibold">
                  <%= reservation.status_label %>
                </span>
              </div>
              <div class="mt-3 text-sm">
                <%= link_to "상세 보기", reservation_path(reservation, token: reservation.access_token),
                    class: "text-indigo-600 hover:text-indigo-800" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8">
          <p class="text-gray-500 mb-4">예약 내역이 없습니다.</p>
          <%= link_to "무료 상담 신청 →", new_reservation_path,
              class: "inline-block bg-indigo-600 text-white px-6 py-3 rounded-xl font-semibold hover:bg-indigo-700 transition-colors" %>
        </div>
      <% end %>
    </div>

    <div class="mt-6 text-center">
      <%= link_to "← 홈으로", root_path, class: "text-gray-600 hover:text-gray-900 text-sm" %>
    </div>
  </div>
</div>
