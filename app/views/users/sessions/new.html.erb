<% content_for :title, "로그인" %>
<% content_for :description, "EnterLab 회원 로그인" %>
<div class="min-h-screen bg-gray-50 py-12 px-4 flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-gray-900">로그인</h1>
        <p class="text-gray-500 text-sm mt-2">회원 계정으로 예약을 관리하세요</p>
      </div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), class: "space-y-4") do |f| %>
        <% if flash[:alert] %>
          <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm" role="alert"><%= flash[:alert] %></div>
        <% end %>

        <div>
          <%= f.label :email, "이메일", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true,
              class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-0 focus:border-indigo-500" %>
        </div>

        <div>
          <%= f.label :password, "비밀번호", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "current-password", required: true,
              class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-0 focus:border-indigo-500" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <label class="flex items-center gap-2 text-sm text-gray-700">
            <%= f.check_box :remember_me, class: "rounded text-indigo-600 focus:ring-indigo-500" %>
            <span>로그인 유지</span>
          </label>
        <% end %>

        <%= f.submit "로그인",
            class: "w-full bg-indigo-600 text-white py-3 rounded-xl font-semibold hover:bg-indigo-700 transition-colors cursor-pointer" %>
      <% end %>

      <div class="mt-6 pt-6 border-t border-gray-100 space-y-2 text-center text-sm">
        <p>
          <%= link_to "비밀번호를 잊으셨나요?", new_password_path(resource_name),
              class: "text-indigo-600 hover:text-indigo-800" %>
        </p>
        <p>
          처음이신가요?
          <%= link_to "회원가입", new_registration_path(resource_name),
              class: "text-indigo-600 hover:text-indigo-800 font-semibold" %>
        </p>
        <p>
          <%= link_to "← 홈으로", root_path, class: "text-gray-500 hover:text-gray-700" %>
        </p>
      </div>
    </div>
  </div>
</div>
