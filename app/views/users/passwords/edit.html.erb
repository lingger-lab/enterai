<% content_for :title, "새 비밀번호 설정" %>
<div class="min-h-screen bg-gray-50 py-12 px-4 flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-gray-900">새 비밀번호 설정</h1>
      </div>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }, class: "space-y-4") do |f| %>
        <%= f.hidden_field :reset_password_token %>
        <% if resource.errors.any? %>
          <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm">
            <ul class="list-disc pl-5">
              <% resource.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :password, "새 비밀번호", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "new-password", required: true, minlength: @minimum_password_length,
              class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-0 focus:border-indigo-500" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "비밀번호 확인", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true,
              class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-0 focus:border-indigo-500" %>
        </div>

        <%= f.submit "비밀번호 변경",
            class: "w-full bg-indigo-600 text-white py-3 rounded-xl font-semibold hover:bg-indigo-700 transition-colors cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>
