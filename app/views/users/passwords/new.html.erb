<% content_for :title, "비밀번호 재설정" %>
<div class="min-h-screen bg-gray-50 py-12 px-4 flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-gray-900">비밀번호 재설정</h1>
        <p class="text-gray-500 text-sm mt-2">가입한 이메일로 재설정 링크를 보내드립니다</p>
      </div>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }, class: "space-y-4") do |f| %>
        <% if flash[:alert] %>
          <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm"><%= flash[:alert] %></div>
        <% end %>
        <% if flash[:notice] %>
          <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl text-sm"><%= flash[:notice] %></div>
        <% end %>

        <div>
          <%= f.label :email, "이메일", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true,
              class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-0 focus:border-indigo-500" %>
        </div>

        <%= f.submit "재설정 링크 받기",
            class: "w-full bg-indigo-600 text-white py-3 rounded-xl font-semibold hover:bg-indigo-700 transition-colors cursor-pointer" %>
      <% end %>

      <div class="mt-6 pt-6 border-t border-gray-100 text-center text-sm">
        <%= link_to "← 로그인으로", new_session_path(resource_name),
            class: "text-indigo-600 hover:text-indigo-800" %>
      </div>
    </div>
  </div>
</div>
