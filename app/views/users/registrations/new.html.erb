<% content_for :title, "회원가입" %>
<% content_for :description, "EnterLab 회원가입 — 예약 관리/내역 확인 등 편의 기능 이용" %>
<div class="min-h-screen bg-gray-50 py-12 px-4 flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-gray-900">회원가입</h1>
        <p class="text-gray-500 text-sm mt-2">예약·후기·학습 자료를 한 곳에서 관리</p>
      </div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), class: "space-y-4") do |f| %>
        <% if resource.errors.any? %>
          <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm">
            <ul class="list-disc pl-5">
              <% resource.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :name, "이름 (닉네임 가능)", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.text_field :name, autocomplete: "name", required: true,
              class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-0 focus:border-indigo-500" %>
        </div>

        <div>
          <%= f.label :email, "이메일", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.email_field :email, autocomplete: "email", required: true,
              class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-0 focus:border-indigo-500" %>
        </div>

        <div>
          <%= f.label :password, "비밀번호 (최소 #{@minimum_password_length}자)", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "new-password", required: true, minlength: @minimum_password_length,
              class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-0 focus:border-indigo-500" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "비밀번호 확인", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true,
              class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-0 focus:border-indigo-500" %>
        </div>

        <!-- 광고성 정보 수신 동의 (선택) -->
        <label class="flex items-start gap-2 text-sm text-gray-700 mt-3">
          <%= f.check_box :marketing_agreed, class: "mt-1 rounded text-indigo-600 focus:ring-indigo-500" %>
          <span>
            <span class="text-gray-500">[선택]</span> 이벤트/혜택 알림 수신에 동의합니다.
            <span class="block text-xs text-gray-500 mt-1">미동의 시에도 가입 가능합니다.</span>
          </span>
        </label>

        <p class="text-xs text-gray-500 leading-relaxed">
          가입 시
          <%= link_to "이용약관", terms_path, target: "_blank", class: "text-indigo-600 underline" %>,
          <%= link_to "개인정보 처리방침", privacy_policy_path, target: "_blank", class: "text-indigo-600 underline" %>
          에 동의한 것으로 간주됩니다.
        </p>

        <%= f.submit "가입하기",
            class: "w-full bg-indigo-600 text-white py-3 rounded-xl font-semibold hover:bg-indigo-700 transition-colors cursor-pointer mt-4" %>
      <% end %>

      <div class="mt-6 pt-6 border-t border-gray-100 text-center text-sm">
        <p>
          이미 회원이신가요?
          <%= link_to "로그인", new_session_path(resource_name),
              class: "text-indigo-600 hover:text-indigo-800 font-semibold" %>
        </p>
      </div>
    </div>
  </div>
</div>
