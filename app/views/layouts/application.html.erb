<!DOCTYPE html>
<html lang="ko">
  <head>
    <title><%= content_for?(:title) ? "#{content_for(:title)} - EnterLab" : "EnterLab - AI 코칭 예약" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <% if content_for?(:noindex) %>
    <meta name="robots" content="noindex,nofollow">
    <% end %>
    <link rel="canonical" href="<%= request.base_url + request.path %>">

    <!-- OG Meta -->
    <meta property="og:title" content="<%= content_for?(:title) ? content_for(:title) : 'EnterLab - AI 1:1 코칭 플랫폼' %>">
    <meta property="og:description" content="<%= content_for?(:description) ? content_for(:description) : 'AI로 당신의 앱을 만들고, 수익을 만드는 1:1 코칭 플랫폼' %>">
    <meta property="og:image" content="<%= request.base_url %>/og-image.png">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="ko_KR">
    <meta property="og:site_name" content="EnterLab">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="description" content="<%= content_for?(:description) ? content_for(:description) : 'AI로 당신의 앱을 만들고, 수익을 만드는 1:1 코칭 플랫폼. 앱개발, 웹페이지개발, 마케팅, 경영, 자금컨설팅' %>">

    <!-- Favicon -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%234f46e5'/><text x='50' y='72' font-size='70' font-weight='bold' font-family='system-ui,sans-serif' fill='white' text-anchor='middle'>E</text></svg>">

    <!-- Pretendard 폰트 (한국어 프리미엄 표준) -->
    <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />

    <!-- Tailwind CSS -->
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <% if Rails.env.production? %>
    <!-- Google Analytics 4 -->
    <script src="https://www.googletagmanager.com/gtag/js?id=G-RJ1JTWX6S5" async nonce="<%= content_security_policy_nonce %>"></script>
    <script nonce="<%= content_security_policy_nonce %>">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-RJ1JTWX6S5');
    </script>
    <% end %>

    <style>
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 4.5rem;
      }
      body {
        font-family: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, system-ui, Roboto, sans-serif;
        word-break: keep-all;
        overflow-wrap: break-word;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      .tabular-nums { font-variant-numeric: tabular-nums; }
      /* 키보드 사용자 포커스 표시 강화 */
      :focus-visible { outline: 2px solid #4f46e5; outline-offset: 2px; }
      /* Skip nav link — 포커스 시에만 보임 */
      .skip-nav { position: absolute; left: -9999px; top: auto; width: 1px; height: 1px; overflow: hidden; }
      .skip-nav:focus { position: fixed; top: 1rem; left: 1rem; width: auto; height: auto; padding: 0.75rem 1rem; background: #4f46e5; color: white; z-index: 9999; border-radius: 0.5rem; font-weight: 600; }
      /* 시니어 친화: 글자 크기 조절 (font-size 컨트롤러) */
      html.font-size-small  { font-size: 14px; }
      html.font-size-normal { font-size: 16px; }
      html.font-size-large  { font-size: 18px; }
    </style>

    <!-- JSON-LD: LocalBusiness + Service -->
    <script type="application/ld+json" nonce="<%= content_security_policy_nonce %>">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "ENTERLABS",
      "alternateName": "EnterLab",
      "description": "AI로 당신의 앱을 만들고, 수익을 만드는 1:1 코칭 플랫폼",
      "url": "https://enterlab.cloud",
      "telephone": "0502-1927-1910",
      "email": "iamblackwhite86@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "대청로26번안길 25-8, 202호(관동동)",
        "addressLocality": "김해시",
        "addressRegion": "경상남도",
        "addressCountry": "KR"
      },
      "priceRange": "₩980,000-₩10,000,000",
      "areaServed": "KR",
      "makesOffer": [
        { "@type": "Offer", "name": "STARTER 코칭", "price": "980000", "priceCurrency": "KRW" },
        { "@type": "Offer", "name": "STANDARD 코칭", "price": "1480000", "priceCurrency": "KRW" },
        { "@type": "Offer", "name": "PREMIUM 코칭", "price": "2490000", "priceCurrency": "KRW" }
      ]
    }
    </script>
  </head>

  <body>
    <!-- Skip navigation (키보드 사용자) -->
    <a href="#main-content" class="skip-nav">본문으로 건너뛰기</a>

    <!-- 네비게이션 헤더 -->
    <nav class="bg-white shadow-sm sticky top-0 z-50" data-controller="mobile-menu">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex items-center">
            <%= link_to root_path, class: "text-2xl font-bold text-indigo-600 hover:text-indigo-700 transition-colors duration-150" do %>
              EnterLab
            <% end %>
          </div>

          <div class="hidden md:flex items-center space-x-6">
            <%= link_to "커리큘럼", root_path(anchor: "curriculum"), class: "text-gray-700 font-medium hover:text-indigo-600 hover:bg-indigo-50 px-4 py-2 rounded-lg transition-all duration-150", data: { turbo: false } %>
            <%= link_to "코치 소개", root_path(anchor: "coach"), class: "text-gray-700 font-medium hover:text-indigo-600 hover:bg-indigo-50 px-4 py-2 rounded-lg transition-all duration-150", data: { turbo: false } %>
            <%= link_to "코칭 패키지", root_path(anchor: "pricing"), class: "text-gray-700 font-medium hover:text-indigo-600 hover:bg-indigo-50 px-4 py-2 rounded-lg transition-all duration-150", data: { turbo: false } %>
            <%= link_to "앱 개발 의뢰", root_path(anchor: "app-development"), class: "text-gray-700 font-medium hover:text-indigo-600 hover:bg-indigo-50 px-4 py-2 rounded-lg transition-all duration-150", data: { turbo: false } %>
            <%= link_to "후기", root_path(anchor: "reviews"), class: "text-gray-700 font-medium hover:text-indigo-600 hover:bg-indigo-50 px-4 py-2 rounded-lg transition-all duration-150", data: { turbo: false } %>
            <%= link_to "FAQ", faq_path, class: "text-gray-700 font-medium hover:text-indigo-600 hover:bg-indigo-50 px-4 py-2 rounded-lg transition-all duration-150" %>
            <%= link_to "예약 조회", lookup_reservations_path, class: "text-gray-700 font-medium hover:text-indigo-600 hover:bg-indigo-50 px-4 py-2 rounded-lg transition-all duration-150" %>
            <%= link_to new_reservation_path,
                        class: "bg-indigo-600 text-white px-5 py-2 rounded-lg font-semibold hover:bg-indigo-600/90 active:scale-[0.98] transition-all duration-150 ml-2",
                        data: { controller: "cta-button" } do %>
              무료 상담 →
            <% end %>
          </div>

          <!-- 모바일 메뉴 버튼 -->
          <div class="md:hidden">
            <button type="button"
                    class="text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 p-2 rounded-md transition-colors duration-150"
                    id="mobile-menu-button"
                    aria-expanded="false"
                    aria-controls="mobile-menu"
                    aria-label="메뉴 열기"
                    data-mobile-menu-target="button"
                    data-action="click->mobile-menu#toggle">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- 모바일 메뉴 -->
      <div class="hidden md:hidden bg-white border-t" id="mobile-menu" data-mobile-menu-target="menu">
        <div class="px-4 py-4 space-y-1">
          <%= link_to "커리큘럼", root_path(anchor: "curriculum"), class: "block text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-2 rounded-md transition-colors duration-150", data: { action: "click->mobile-menu#close", turbo: false } %>
          <%= link_to "코치 소개", root_path(anchor: "coach"), class: "block text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-2 rounded-md transition-colors duration-150", data: { action: "click->mobile-menu#close", turbo: false } %>
          <%= link_to "코칭 패키지", root_path(anchor: "pricing"), class: "block text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-2 rounded-md transition-colors duration-150", data: { action: "click->mobile-menu#close", turbo: false } %>
          <%= link_to "앱 개발 의뢰", root_path(anchor: "app-development"), class: "block text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-2 rounded-md transition-colors duration-150", data: { action: "click->mobile-menu#close", turbo: false } %>
          <%= link_to "후기", root_path(anchor: "reviews"), class: "block text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-2 rounded-md transition-colors duration-150", data: { action: "click->mobile-menu#close", turbo: false } %>
          <%= link_to "FAQ", faq_path, class: "block text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-2 rounded-md transition-colors duration-150", data: { action: "click->mobile-menu#close" } %>
          <%= link_to "예약 조회", lookup_reservations_path, class: "block text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-2 rounded-md transition-colors duration-150", data: { action: "click->mobile-menu#close" } %>
          <%= link_to new_reservation_path,
                      class: "block bg-indigo-600 text-white px-4 py-2 rounded-lg font-semibold hover:bg-indigo-600/90 active:scale-[0.98] transition-all duration-150 text-center mt-2",
                      data: { controller: "cta-button", action: "click->mobile-menu#close" } do %>
            무료 상담 →
          <% end %>
        </div>
      </div>
    </nav>

    <main id="main-content">
      <%= yield %>
    </main>
  </body>
</html>
