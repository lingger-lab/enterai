<!DOCTYPE html>
<html>
  <head>
    <title>EnterLab - AI 코칭 예약</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- OG Meta -->
    <meta property="og:title" content="EnterLab - AI 1:1 코칭 플랫폼">
    <meta property="og:description" content="AI로 당신의 앱을 만들고, 수익을 만드는 1:1 코칭 플랫폼">
    <meta property="og:image" content="<%= request.base_url %>/og-image.png">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="EnterLab">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="description" content="AI로 당신의 앱을 만들고, 수익을 만드는 1:1 코칭 플랫폼. 앱개발, 웹페이지개발, 마케팅, 경영, 자금컨설팅">

    <!-- Favicon -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🤖</text></svg>">

    <!-- Tailwind CSS -->
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 4.5rem;
      }
    </style>
  </head>

  <body>
    <!-- 네비게이션 헤더 -->
    <nav class="bg-white shadow-sm sticky top-0 z-50" data-controller="mobile-menu">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex items-center">
            <%= link_to root_path, class: "text-2xl font-bold text-indigo-600 hover:text-indigo-700 transition-colors duration-150" do %>
              EnterLab
            <% end %>
          </div>

          <div class="hidden md:flex items-center space-x-6">
            <%= link_to "커리큘럼", "#curriculum", class: "text-gray-700 font-medium hover:text-indigo-600 hover:bg-indigo-50 px-4 py-2 rounded-lg transition-all duration-150", data: { turbo: false } %>
            <%= link_to "코치 소개", "#coach", class: "text-gray-700 font-medium hover:text-indigo-600 hover:bg-indigo-50 px-4 py-2 rounded-lg transition-all duration-150", data: { turbo: false } %>
            <%= link_to "코칭 패키지", "#pricing", class: "text-gray-700 font-medium hover:text-indigo-600 hover:bg-indigo-50 px-4 py-2 rounded-lg transition-all duration-150", data: { turbo: false } %>
            <%= link_to "앱 개발 의뢰", "#app-development", class: "text-gray-700 font-medium hover:text-indigo-600 hover:bg-indigo-50 px-4 py-2 rounded-lg transition-all duration-150", data: { turbo: false } %>
            <%= link_to "후기", "#reviews", class: "text-gray-700 font-medium hover:text-indigo-600 hover:bg-indigo-50 px-4 py-2 rounded-lg transition-all duration-150", data: { turbo: false } %>
            <%= link_to "예약 조회", lookup_reservations_path, class: "text-gray-700 font-medium hover:text-indigo-600 hover:bg-indigo-50 px-4 py-2 rounded-lg transition-all duration-150" %>
            <%= link_to new_reservation_path,
                        class: "bg-indigo-600 text-white px-5 py-2 rounded-lg font-semibold hover:bg-indigo-600/90 active:scale-[0.98] transition-all duration-150 ml-2",
                        data: { controller: "cta-button" } do %>
              무료 상담 →
            <% end %>
          </div>

          <!-- 모바일 메뉴 버튼 -->
          <div class="md:hidden">
            <button type="button" class="text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 p-2 rounded-md transition-colors duration-150" id="mobile-menu-button" data-action="click->mobile-menu#toggle">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- 모바일 메뉴 -->
      <div class="hidden md:hidden bg-white border-t" id="mobile-menu" data-mobile-menu-target="menu">
        <div class="px-4 py-4 space-y-1">
          <%= link_to "커리큘럼", "#curriculum", class: "block text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-2 rounded-md transition-colors duration-150", data: { action: "click->mobile-menu#close", turbo: false } %>
          <%= link_to "코치 소개", "#coach", class: "block text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-2 rounded-md transition-colors duration-150", data: { action: "click->mobile-menu#close", turbo: false } %>
          <%= link_to "코칭 패키지", "#pricing", class: "block text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-2 rounded-md transition-colors duration-150", data: { action: "click->mobile-menu#close", turbo: false } %>
          <%= link_to "앱 개발 의뢰", "#app-development", class: "block text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-2 rounded-md transition-colors duration-150", data: { action: "click->mobile-menu#close", turbo: false } %>
          <%= link_to "후기", "#reviews", class: "block text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-2 rounded-md transition-colors duration-150", data: { action: "click->mobile-menu#close", turbo: false } %>
          <%= link_to "예약 조회", lookup_reservations_path, class: "block text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-2 rounded-md transition-colors duration-150", data: { action: "click->mobile-menu#close" } %>
          <%= link_to new_reservation_path,
                      class: "block bg-indigo-600 text-white px-4 py-2 rounded-lg font-semibold hover:bg-indigo-600/90 active:scale-[0.98] transition-all duration-150 text-center mt-2",
                      data: { controller: "cta-button", action: "click->mobile-menu#close" } do %>
            무료 상담 →
          <% end %>
        </div>
      </div>
    </nav>

    <%= yield %>
  </body>
</html>
