<!DOCTYPE html>
<html>
  <head>
    <title>EnterLab 관리자</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex,nofollow,noarchive">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 min-h-screen">
    <!-- 상단 네비게이션 -->
    <nav class="bg-indigo-700 text-white shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-14">
          <div class="flex items-center space-x-6">
            <%= link_to "EnterLab Admin", admin_root_path, class: "text-lg font-bold" %>
            <%= link_to "예약 관리", admin_reservations_path, class: "text-indigo-200 hover:text-white text-sm" %>
            <%= link_to "슬롯 관리", admin_time_slots_path, class: "text-indigo-200 hover:text-white text-sm" %>
            <%= link_to "후기 관리", admin_reviews_path, class: "text-indigo-200 hover:text-white text-sm" %>
          </div>
          <div class="flex items-center space-x-4">
            <%= link_to "홈으로", root_path, class: "text-indigo-200 hover:text-white text-sm", target: "_blank" %>
            <span class="text-indigo-200 text-sm"><%= current_admin_user.email %></span>
            <%= button_to "로그아웃", destroy_admin_user_session_path, method: :delete,
                class: "text-indigo-200 hover:text-white text-sm" %>
          </div>
        </div>
      </div>
    </nav>

    <!-- 플래시 메시지 -->
    <% if notice %>
      <div class="max-w-7xl mx-auto px-4 mt-4">
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg text-sm">
          <%= notice %>
        </div>
      </div>
    <% end %>
    <% if alert %>
      <div class="max-w-7xl mx-auto px-4 mt-4">
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm">
          <%= alert %>
        </div>
      </div>
    <% end %>

    <!-- 메인 콘텐츠 -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <%= yield %>
    </main>
  </body>
</html>
