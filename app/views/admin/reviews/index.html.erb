<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-gray-900">후기 관리</h1>
    <div class="flex space-x-2">
      <%= link_to "전체", admin_reviews_path, class: "px-3 py-1.5 rounded-lg text-sm font-medium #{params[:published].blank? ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700'}" %>
      <%= link_to "공개", admin_reviews_path(published: "true"), class: "px-3 py-1.5 rounded-lg text-sm font-medium #{params[:published] == 'true' ? 'bg-green-600 text-white' : 'bg-gray-100 text-gray-700'}" %>
      <%= link_to "비공개", admin_reviews_path(published: "false"), class: "px-3 py-1.5 rounded-lg text-sm font-medium #{params[:published] == 'false' ? 'bg-gray-600 text-white' : 'bg-gray-100 text-gray-700'}" %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">작성자</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">별점</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">내용</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">카테고리</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">상태</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">작성일</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">관리</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @reviews.each do |review| %>
          <tr>
            <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= review.author_name %></td>
            <td class="px-4 py-3 text-sm text-yellow-500"><%= "★" * review.rating %><%= "☆" * (5 - review.rating) %></td>
            <td class="px-4 py-3 text-sm text-gray-700 max-w-xs truncate"><%= review.content %></td>
            <td class="px-4 py-3 text-sm text-gray-500"><%= review.category || "-" %></td>
            <td class="px-4 py-3">
              <% if review.is_published? %>
                <span class="px-2 py-1 text-xs font-medium rounded-full bg-green-100 text-green-700">공개</span>
              <% else %>
                <span class="px-2 py-1 text-xs font-medium rounded-full bg-gray-100 text-gray-600">비공개</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm text-gray-500"><%= review.created_at.strftime("%m/%d") %></td>
            <td class="px-4 py-3">
              <%= button_to review.is_published? ? "비공개" : "공개",
                  toggle_publish_admin_review_path(review),
                  method: :patch,
                  class: "text-xs px-3 py-1 rounded-lg #{review.is_published? ? 'text-red-600 hover:bg-red-50' : 'text-green-600 hover:bg-green-50'}" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
