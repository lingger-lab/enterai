<div class="space-y-6">
  <div class="flex items-center space-x-4">
    <%= link_to "← 상세", admin_reservation_path(@reservation), class: "text-gray-500 hover:text-gray-700 text-sm" %>
    <h1 class="text-2xl font-bold text-gray-900">예약 수정 #<%= @reservation.id %></h1>
  </div>

  <div class="max-w-2xl bg-white rounded-xl shadow-sm p-6">
    <%= form_with(model: @reservation, url: admin_reservation_path(@reservation), method: :patch, class: "space-y-6") do |f| %>
      <% if @reservation.errors.any? %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm">
          <ul class="list-disc pl-4">
            <% @reservation.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">패키지</label>
        <%= f.select :package, Reservation::PACKAGES.map { |k, v| ["#{v[:name]} (#{(v[:price] / 10000).to_i}만원)", k] },
            {}, class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">예약 일시</label>
        <%= f.datetime_local_field :reservation_datetime,
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        <p class="mt-1 text-xs text-gray-500">일정을 변경하면 고객에게 SMS가 자동 발송됩니다.</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">코칭 형태</label>
        <%= f.select :coaching_type, Reservation::COACHING_TYPES.map { |t| [t, t] },
            {}, class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">상태</label>
        <%= f.select :status, Reservation::STATUSES.map { |s| [Reservation::STATUS_LABELS[s], s] },
            {}, class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">선택 과목</label>
        <div class="grid grid-cols-2 gap-2 mt-2">
          <% Reservation::SUBJECT_OPTIONS.each do |subject| %>
            <label class="flex items-center space-x-2">
              <%= check_box_tag "reservation[selected_subjects][]", subject,
                  @reservation.selected_subjects&.include?(subject),
                  class: "h-4 w-4 text-indigo-600 border-gray-300 rounded" %>
              <span class="text-sm text-gray-700"><%= subject %></span>
            </label>
          <% end %>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">요청사항</label>
        <%= f.text_area :requests, rows: 4,
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div class="flex justify-end space-x-3 pt-4 border-t">
        <%= link_to "취소", admin_reservation_path(@reservation),
            class: "px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50" %>
        <%= f.submit "저장", class: "px-6 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
