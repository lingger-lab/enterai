<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-gray-900">예약 관리</h1>
    <p class="text-sm text-gray-500">총 <%= @stats[:total] %>건</p>
  </div>

  <!-- 대시보드 통계 -->
  <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-3">
    <div class="bg-white rounded-lg shadow-sm p-4 text-center">
      <p class="text-2xl font-bold text-gray-900"><%= @stats[:total] %></p>
      <p class="text-xs text-gray-500 mt-1">전체</p>
    </div>
    <div class="bg-white rounded-lg shadow-sm p-4 text-center">
      <p class="text-2xl font-bold text-yellow-600"><%= @stats[:pending] %></p>
      <p class="text-xs text-gray-500 mt-1">대기중</p>
    </div>
    <div class="bg-white rounded-lg shadow-sm p-4 text-center">
      <p class="text-2xl font-bold text-green-600"><%= @stats[:confirmed] %></p>
      <p class="text-xs text-gray-500 mt-1">확정</p>
    </div>
    <div class="bg-white rounded-lg shadow-sm p-4 text-center">
      <p class="text-2xl font-bold text-red-600"><%= @stats[:cancelled] %></p>
      <p class="text-xs text-gray-500 mt-1">취소</p>
    </div>
    <div class="bg-white rounded-lg shadow-sm p-4 text-center">
      <p class="text-2xl font-bold text-blue-600"><%= @stats[:completed] %></p>
      <p class="text-xs text-gray-500 mt-1">완료</p>
    </div>
    <div class="bg-white rounded-lg shadow-sm p-4 text-center">
      <p class="text-2xl font-bold text-indigo-600"><%= @stats[:today] %></p>
      <p class="text-xs text-gray-500 mt-1">오늘 예약</p>
    </div>
    <div class="bg-white rounded-lg shadow-sm p-4 text-center">
      <p class="text-2xl font-bold text-purple-600"><%= @stats[:this_week] %></p>
      <p class="text-xs text-gray-500 mt-1">이번주 접수</p>
    </div>
  </div>

  <!-- 상태 필터 탭 -->
  <div class="flex space-x-1 bg-white rounded-lg shadow-sm p-1">
    <%= link_to "전체", admin_reservations_path,
        class: "px-4 py-2 text-sm font-medium rounded-md #{params[:status].blank? ? 'bg-indigo-600 text-white' : 'text-gray-600 hover:bg-gray-100'}" %>
    <% Reservation::STATUSES.each do |status| %>
      <%= link_to Reservation::STATUS_LABELS[status], admin_reservations_path(status: status),
          class: "px-4 py-2 text-sm font-medium rounded-md #{params[:status] == status ? 'bg-indigo-600 text-white' : 'text-gray-600 hover:bg-gray-100'}" %>
    <% end %>
  </div>

  <!-- 예약 테이블 -->
  <div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">이름</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">연락처</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">예약일시</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">패키지</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">코칭형태</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">상태</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">접수일</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200" id="reservations-table">
        <% @reservations.each do |reservation| %>
          <%= render partial: "admin/reservations/reservation", locals: { reservation: reservation } %>
        <% end %>
        <% if @reservations.empty? %>
          <tr>
            <td colspan="9" class="px-6 py-12 text-center text-gray-400">예약이 없습니다.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- 페이지네이션 -->
  <div class="flex justify-center">
    <%== pagy_nav(@pagy) %>
  </div>
</div>
