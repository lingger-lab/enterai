<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-gray-900">시간 슬롯 관리</h1>
    <div class="flex space-x-3">
      <%= link_to "단일 생성", new_admin_time_slot_path, class: "px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      <%= link_to "일괄 생성", bulk_new_admin_time_slots_path, class: "px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700" %>
    </div>
  </div>

  <!-- 통계 -->
  <div class="grid grid-cols-4 gap-4">
    <div class="bg-white rounded-xl shadow-sm p-4 text-center">
      <div class="text-2xl font-bold text-gray-900"><%= @stats[:total] %></div>
      <div class="text-sm text-gray-500">전체</div>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-4 text-center">
      <div class="text-2xl font-bold text-green-600"><%= @stats[:available] %></div>
      <div class="text-sm text-gray-500">예약 가능</div>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-4 text-center">
      <div class="text-2xl font-bold text-blue-600"><%= @stats[:booked] %></div>
      <div class="text-sm text-gray-500">예약됨</div>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-4 text-center">
      <div class="text-2xl font-bold text-red-600"><%= @stats[:blocked] %></div>
      <div class="text-sm text-gray-500">차단됨</div>
    </div>
  </div>

  <!-- 월 네비게이션 -->
  <div class="flex items-center justify-between bg-white rounded-xl shadow-sm p-4">
    <%= link_to "← 이전 달", admin_time_slots_path(month: (@month - 1.month).strftime("%Y-%m")), class: "text-sm text-gray-600 hover:text-gray-900" %>
    <span class="text-lg font-bold text-gray-900"><%= @month.strftime("%Y년 %m월") %></span>
    <%= link_to "다음 달 →", admin_time_slots_path(month: (@month + 1.month).strftime("%Y-%m")), class: "text-sm text-gray-600 hover:text-gray-900" %>
  </div>

  <!-- 코칭 타입 필터 -->
  <div class="flex space-x-2">
    <%= link_to "전체", admin_time_slots_path(month: @month.strftime("%Y-%m")),
        class: "px-3 py-1.5 rounded-lg text-sm font-medium #{params[:coaching_type].blank? ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
    <% Reservation::COACHING_TYPES.each do |type| %>
      <%= link_to type, admin_time_slots_path(month: @month.strftime("%Y-%m"), coaching_type: type),
          class: "px-3 py-1.5 rounded-lg text-sm font-medium #{params[:coaching_type] == type ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
    <% end %>
  </div>

  <!-- 날짜별 슬롯 목록 -->
  <% if @slots_by_date.empty? %>
    <div class="bg-white rounded-xl shadow-sm p-12 text-center text-gray-500">
      이 달에 등록된 슬롯이 없습니다.
    </div>
  <% else %>
    <% @slots_by_date.each do |date, slots| %>
      <div class="bg-white rounded-xl shadow-sm p-6">
        <h3 class="text-base font-semibold text-gray-900 mb-4">
          <%= date.strftime("%m/%d (%a)") %>
          <span class="text-sm font-normal text-gray-500 ml-2"><%= slots.count %>개 슬롯</span>
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
          <% slots.each do |slot| %>
            <div class="flex items-center justify-between p-3 rounded-lg border
              <%= case slot.status
                  when 'available' then 'border-green-200 bg-green-50'
                  when 'booked' then 'border-blue-200 bg-blue-50'
                  when 'blocked' then 'border-red-200 bg-red-50'
                  end %>">
              <div>
                <div class="text-sm font-medium text-gray-900"><%= slot.time_range_label %></div>
                <div class="text-xs text-gray-500"><%= slot.coaching_type %></div>
              </div>
              <div class="flex space-x-1">
                <% if slot.available? || slot.status == "blocked" %>
                  <%= button_to slot.available? ? "차단" : "활성",
                      toggle_block_admin_time_slot_path(slot),
                      method: :patch,
                      class: "text-xs px-2 py-1 rounded #{slot.available? ? 'text-red-600 hover:bg-red-100' : 'text-green-600 hover:bg-green-100'}" %>
                <% end %>
                <% unless slot.booked? %>
                  <%= button_to "삭제",
                      admin_time_slot_path(slot),
                      method: :delete,
                      data: { turbo_confirm: "이 슬롯을 삭제하시겠습니까?" },
                      class: "text-xs px-2 py-1 rounded text-gray-500 hover:bg-gray-100" %>
                <% end %>
                <% if slot.booked? && slot.reservation %>
                  <%= link_to "예약##{slot.reservation.id}",
                      admin_reservation_path(slot.reservation),
                      class: "text-xs px-2 py-1 rounded text-blue-600 hover:bg-blue-100" %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
