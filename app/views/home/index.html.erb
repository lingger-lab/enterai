<!-- ============================================ -->
<!-- 히어로 섹션 -->
<!-- ============================================ -->
<section class="min-h-[70vh] sm:min-h-[80vh] bg-gradient-to-br from-indigo-50 via-white to-purple-50 flex items-center justify-center px-4 sm:px-6 lg:px-8" data-controller="magnetic-text">
  <div class="max-w-7xl mx-auto text-center">
    <h1 class="text-[1.65rem] sm:text-4xl md:text-6xl font-bold text-gray-900 mb-4 sm:mb-6 leading-tight" data-magnetic-text-target="text">
      AI로 당신의 <span class="text-indigo-600">앱</span>을 만들고,<br>
      <span class="text-indigo-600">수익</span>을 만듭니다.
    </h1>
    <p class="text-[0.95rem] sm:text-xl md:text-2xl text-indigo-700 mb-3 sm:mb-4 max-w-3xl mx-auto font-semibold" data-magnetic-text-target="text">
      혼자서는 1년 | 1:1 코칭 | 4주 앱 완성
    </p>
    <p class="text-[0.9rem] sm:text-base md:text-lg text-gray-500 mb-3 sm:mb-4 max-w-3xl mx-auto" data-magnetic-text-target="text">
      50대 시니어 기획자가 직접 AI로 창업한 경험을 —<br>
      당신에게 1:1로 전수합니다.
    </p>
    <p class="text-sm text-gray-400 mb-6 sm:mb-8" data-magnetic-text-target="text">무료 상담 · 부담 없는 첫 만남 · 3분이면 예약 완료</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <%= link_to new_reservation_path,
                  class: "bg-indigo-600 text-white px-8 py-4 rounded-lg font-semibold text-lg shadow-lg shadow-indigo-600/25 hover:bg-indigo-700 hover:shadow-xl hover:scale-105 hover:-translate-y-0.5 active:scale-[0.97] transition-all duration-200",
                  data: { controller: "cta-button" } do %>
        무료 상담 신청하기 →
      <% end %>
      <a href="#pricing"
         data-turbo="false"
         class="bg-white text-indigo-600 border-2 border-indigo-600 px-8 py-4 rounded-lg font-semibold text-lg shadow-md hover:bg-indigo-50 hover:scale-105 hover:-translate-y-0.5 active:scale-[0.97] transition-all duration-200">
        코칭 패키지 보기
      </a>
    </div>
  </div>
</section>

<!-- ============================================ -->
<!-- 문제 공감 섹션 (페르소나별 탭) -->
<!-- ============================================ -->
<section class="py-6 sm:py-20 bg-white" data-controller="tabs">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8 sm:mb-12" data-controller="scroll-reveal">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-4" data-scroll-reveal-target="item">혹시 이런 고민 하고 계신가요?</h2>
    </div>

    <!-- 탭 버튼 -->
    <div class="flex flex-wrap justify-center gap-2 sm:gap-4 mb-8 sm:mb-10">
      <button data-action="click->tabs#switch" data-tabs-target="btn" data-index="0"
              class="px-3 sm:px-6 py-2 sm:py-3 rounded-full font-semibold text-xs sm:text-base border-2 border-indigo-600 bg-indigo-600 text-white transition-all">
        💼 직장인이라면
      </button>
      <button data-action="click->tabs#switch" data-tabs-target="btn" data-index="1"
              class="px-3 sm:px-6 py-2 sm:py-3 rounded-full font-semibold text-xs sm:text-base border-2 border-gray-300 text-gray-600 hover:border-indigo-400 transition-all">
        🏠 50대 이상이라면
      </button>
      <button data-action="click->tabs#switch" data-tabs-target="btn" data-index="2"
              class="px-3 sm:px-6 py-2 sm:py-3 rounded-full font-semibold text-xs sm:text-base border-2 border-gray-300 text-gray-600 hover:border-indigo-400 transition-all">
        🏪 소상공인이라면
      </button>
    </div>

    <!-- 직장인 탭 -->
    <div data-tabs-target="panel" class="bg-gradient-to-br from-indigo-50 to-purple-50 rounded-2xl p-6 sm:p-8 md:p-12" data-controller="stream-card">
      <p class="text-xl sm:text-2xl font-bold text-gray-900 mb-4">"회사 월급만으로는 불안하지 않으세요?"</p>
      <div class="space-y-3 text-base sm:text-lg text-gray-700 mb-6 sm:mb-8">
        <p>✔ AI를 못하면 도태된다는데, 뭐부터 해야 할지 막막하고</p>
        <p>✔ 부업하고 싶지만 방법을 모르고</p>
        <p>✔ 혼자 공부하면 포기할 것 같고</p>
      </div>
      <div class="bg-white rounded-xl p-5 sm:p-6 border-l-4 border-indigo-600">
        <p class="text-lg sm:text-xl font-bold text-indigo-700">퇴근 후 2시간, 4주 만에 당신만의 앱을 만들어 드립니다.</p>
        <p class="text-gray-600 mt-2">코딩을 몰라도 AI가 다 해줍니다. 코치가 1:1로 잡아주니까 포기할 수가 없습니다.</p>
      </div>
    </div>

    <!-- 시니어 탭 -->
    <div data-tabs-target="panel" class="bg-gradient-to-br from-amber-50 to-orange-50 rounded-2xl p-6 sm:p-8 md:p-12 hidden" data-controller="stream-card">
      <p class="text-xl sm:text-2xl font-bold text-gray-900 mb-4">"은퇴 후, 뭘 해야 할지 막막하셨죠?"</p>
      <div class="space-y-3 text-base sm:text-lg text-gray-700 mb-6 sm:mb-8">
        <p>✔ 나이 때문에 늦은 게 아닐까 걱정되고</p>
        <p>✔ 기술이 어려울 것 같아 두렵고</p>
        <p>✔ 주변에 물어볼 사람이 없고</p>
      </div>
      <div class="bg-white rounded-xl p-5 sm:p-6 border-l-4 border-amber-600">
        <p class="text-lg sm:text-xl font-bold text-amber-700">같은 50대인 코치가 1:1로 함께 만들어 드립니다.</p>
        <p class="text-gray-600 mt-2">늦은 나이가 오히려 무기가 됩니다. 당신의 경험 + AI = 수익화 앱.</p>
      </div>
    </div>

    <!-- 소상공인 탭 -->
    <div data-tabs-target="panel" class="bg-gradient-to-br from-emerald-50 to-green-50 rounded-2xl p-6 sm:p-8 md:p-12 hidden" data-controller="stream-card">
      <p class="text-xl sm:text-2xl font-bold text-gray-900 mb-4">"배달앱 수수료 30%, 언제까지 내실 건가요?"</p>
      <div class="space-y-3 text-base sm:text-lg text-gray-700 mb-6 sm:mb-8">
        <p>✔ 매출은 정체되고, 동네에 같은 업종 경쟁은 심해지고</p>
        <p>✔ AI를 도입하고 싶지만 어디서부터 시작해야 할지 모르고</p>
        <p>✔ 가게 운영하랴 바빠서 공부할 시간은 없고</p>
      </div>
      <div class="bg-white rounded-xl p-5 sm:p-6 border-l-4 border-emerald-600">
        <p class="text-lg sm:text-xl font-bold text-emerald-700">내 가게 전용 앱, 4주면 나옵니다.</p>
        <p class="text-gray-600 mt-2">강의가 아니라 프로젝트입니다. 주문 앱, 예약 앱, 고객관리 앱 — 당신 사업에 딱 맞는 걸 함께 만듭니다.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============================================ -->
<!-- 커리큘럼 섹션 -->
<!-- ============================================ -->
<section id="curriculum" class="py-6 sm:py-20 bg-gray-50" data-controller="tabs">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8 sm:mb-12" data-controller="scroll-reveal">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-4" data-scroll-reveal-target="item">커리큘럼</h2>
      <p class="text-lg text-gray-600" data-scroll-reveal-target="item">코딩을 몰라도 됩니다. AI가 코드를 쓰고, 코치가 방향을 잡고, 당신은 아이디어만 내면 됩니다.</p>
      <p class="mt-4 text-base font-semibold text-slate-700 bg-slate-50 inline-block px-4 py-2 rounded-lg border border-slate-200" data-scroll-reveal-target="item">*강의의 품질을 위해 한달에 최대 4명만 수강가능합니다.</p>
      <p class="mt-2 text-sm text-gray-500" data-scroll-reveal-target="item">주의: 출장강의의 경우 김해장유를 중심으로 반경 100Km까지 가능하고 출장비가 추가될 수 있습니다.</p>
    </div>

    <div class="flex flex-wrap justify-center gap-2 sm:gap-4 mb-8 sm:mb-10">
      <button data-action="click->tabs#switch" data-tabs-target="btn" data-index="0"
              class="px-3 sm:px-6 py-2 sm:py-3 rounded-full font-semibold text-xs sm:text-base border-2 border-indigo-600 bg-indigo-600 text-white transition-all">
        직장인 코스 (4주)
      </button>
      <button data-action="click->tabs#switch" data-tabs-target="btn" data-index="1"
              class="px-3 sm:px-6 py-2 sm:py-3 rounded-full font-semibold text-xs sm:text-base border-2 border-gray-300 text-gray-600 hover:border-indigo-400 transition-all">
        시니어 코스 (6주)
      </button>
      <button data-action="click->tabs#switch" data-tabs-target="btn" data-index="2"
              class="px-3 sm:px-6 py-2 sm:py-3 rounded-full font-semibold text-xs sm:text-base border-2 border-gray-300 text-gray-600 hover:border-indigo-400 transition-all">
        소상공인 코스 (6주) <span class="text-[10px] sm:text-xs bg-red-500 text-white px-1.5 py-0.5 rounded-full ml-1 align-middle">NEW</span>
      </button>
    </div>

    <!-- 직장인 커리큘럼 -->
    <div data-tabs-target="panel" class="space-y-4" data-controller="scroll-reveal" data-scroll-reveal-stagger-value="100">
      <% [
        { week: "1주차", title: "AI 기초 + 앱 기획", desc: "ChatGPT/Claude 핵심 활용법 · 바이브코딩 개념 · 내 부업에 맞는 앱 아이디어 선정 · 수익모델 구상", result: "앱 기획서 + 수익화 로드맵" },
        { week: "2주차", title: "앱 개발 실전", desc: "Cursor AI 활용 실습 · 프론트엔드 UI 만들기 · 핵심 기능 구현 · 데이터베이스 연결", result: "앱 MVP + 주요 화면 3개 이상" },
        { week: "3주차", title: "완성 + 배포", desc: "앱 완성도 높이기 · 무료 배포(Vercel/GCP) · 도메인 연결 · 실전 테스트 + 버그 수정", result: "배포된 실제 앱 URL" },
        { week: "4주차", title: "수익화 + 마케팅", desc: "AI로 마케팅 콘텐츠 자동 생성 · SNS 홍보 전략 · 수익화 채널 세팅 · 운영 가이드", result: "마케팅 콘텐츠 5개+ · 수익화 채널 완료" },
      ].each do |w| %>
        <div class="bg-gradient-to-r from-indigo-50 to-white rounded-xl p-5 sm:p-6 border border-indigo-100" data-scroll-reveal-target="item">
          <div class="flex items-start gap-3 sm:gap-4">
            <div class="bg-indigo-600 text-white px-3 py-1 rounded-lg font-bold text-sm whitespace-nowrap"><%= w[:week] %></div>
            <div class="flex-1">
              <h4 class="font-bold text-lg text-gray-900"><%= w[:title] %></h4>
              <p class="text-gray-600 mt-1 text-sm sm:text-base"><%= w[:desc] %></p>
              <p class="text-indigo-700 font-semibold mt-2 text-sm">📦 성과물: <%= w[:result] %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- 시니어 커리큘럼 -->
    <div data-tabs-target="panel" class="space-y-4 hidden" data-controller="scroll-reveal" data-scroll-reveal-stagger-value="100">
      <% [
        { week: "1주차", title: "디지털 기초 + AI 체험", desc: "스마트폰/PC 환경 세팅 · ChatGPT/Claude 처음부터 배우기 · AI로 할 수 있는 일 체험 · 내 경험과 AI 연결", result: "AI 도구 세팅 완료 + 자신감 확보" },
        { week: "2주차", title: "앱 아이디어 발굴", desc: "내 경력/전문성 기반 앱 기획 · 타겟 고객 정의 · 수익모델 설계(B2B/B2C) · 프로토타입 화면 설계", result: "앱 기획서 + 화면설계서" },
        { week: "3~4주차", title: "앱 개발 (바이브코딩)", desc: "Cursor AI 활용 실습(천천히, 단계별) · UI → 기능 → 데이터 연결 · 질문하면서 배우는 1:1 실습", result: "실제 동작하는 앱 완성" },
        { week: "5주차", title: "배포 + 사업화", desc: "앱 배포(무료 서버) · 사업자 등록/결제 연결 · 납품/계약 전략 · AI 마케팅 콘텐츠 제작", result: "운영 가능한 앱 + 사업자등록 + 영업 자료" },
        { week: "6주차", title: "수익화 전략 + 로드맵", desc: "첫 고객 확보 전략 · AI 자동화 운영 구축 · 확장 로드맵(추가 앱/서비스) · 월 1회 멘토링 계획", result: "6개월 수익화 로드맵 + 확장 사업 기획서" },
      ].each do |w| %>
        <div class="bg-gradient-to-r from-amber-50 to-white rounded-xl p-5 sm:p-6 border border-amber-100" data-scroll-reveal-target="item">
          <div class="flex items-start gap-3 sm:gap-4">
            <div class="bg-amber-600 text-white px-3 py-1 rounded-lg font-bold text-sm whitespace-nowrap"><%= w[:week] %></div>
            <div class="flex-1">
              <h4 class="font-bold text-lg text-gray-900"><%= w[:title] %></h4>
              <p class="text-gray-600 mt-1 text-sm sm:text-base"><%= w[:desc] %></p>
              <p class="text-amber-700 font-semibold mt-2 text-sm">📦 성과물: <%= w[:result] %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- 소상공인 커리큘럼 -->
    <div data-tabs-target="panel" class="space-y-4 hidden" data-controller="scroll-reveal" data-scroll-reveal-stagger-value="100">
      <% [
        { week: "1주차", title: "내 가게 분석 + AI 기획", desc: "매출 구조·배달앱 수수료·고객 흐름 분석 · ChatGPT/Claude 프롬프트 실습 · 주문앱 vs 예약앱 vs 고객관리앱 — 내 업종에 맞는 앱 결정", result: "가게 분석 보고서 + 앱 기획서 + ROI 예측표" },
        { week: "2주차", title: "앱 개발 실전 (Cursor AI)", desc: "Cursor AI로 직접 앱 만들기 · 메뉴/상품 등록 · 주문/예약 시스템 · 고객 포인트 적립 · 사장님 전용 관리자 페이지 구현", result: "앱 베타 버전 + 관리자 페이지 + 테스트 주문 실습" },
        { week: "3주차", title: "앱 완성 + 배포 + 카카오 연동", desc: "가게 로고·브랜딩 반영 디자인 마무리 · 무료 서버 배포(추가 비용 無) · 카카오톡 채널 연동 + AI 챗봇 자동응답 · 매장용 QR코드 제작", result: "완성형 앱 배포 + 카카오톡 채널 연동 + QR코드" },
        { week: "4주차", title: "고객관리 + 마케팅 자동화", desc: "포인트 적립→재방문 쿠폰 자동 발송 · 생일 축하/할인 알림 자동화 · AI로 인스타·블로그 콘텐츠 제작 · 배달앱→자체앱 전환 홍보 전략", result: "고객관리 자동화 + 마케팅 콘텐츠 5개+" },
        { week: "5주차", title: "매출 최적화 + 데이터 분석", desc: "주문/예약 데이터 분석 · 인기 메뉴·피크 시간대 파악 · 가격 전략 최적화 · 재방문율·신규 고객 유입 측정 · 배달앱 수수료 절감액 확인", result: "매출 분석 대시보드 + 최적화 전략 보고서" },
        { week: "6주차", title: "ROI 확인 + 자립 운영 세팅", desc: "ROI 측정(수수료 절감액·재방문율·매출 증가) · 사장님 혼자 운영 가능하도록 매뉴얼 제작 · 확장 전략(2호점/신메뉴) · 3개월 Q&A 지원 시작", result: "ROI 보고서 + 운영 매뉴얼 + 3개월 Q&A 시작" },
      ].each do |w| %>
        <div class="bg-gradient-to-r from-emerald-50 to-white rounded-xl p-5 sm:p-6 border border-emerald-100" data-scroll-reveal-target="item">
          <div class="flex items-start gap-3 sm:gap-4">
            <div class="bg-emerald-600 text-white px-3 py-1 rounded-lg font-bold text-sm whitespace-nowrap"><%= w[:week] %></div>
            <div class="flex-1">
              <h4 class="font-bold text-lg text-gray-900"><%= w[:title] %></h4>
              <p class="text-gray-600 mt-1 text-sm sm:text-base"><%= w[:desc] %></p>
              <p class="text-emerald-700 font-semibold mt-2 text-sm">📦 성과물: <%= w[:result] %></p>
            </div>
          </div>
        </div>
      <% end %>
      <div class="mt-4 p-4 bg-emerald-50 rounded-xl border border-emerald-200 text-center">
        <p class="text-sm text-emerald-800 font-semibold">💡 "코칭비 80만원 → 수수료 월 25만원 절감 → 3개월 만에 회수" — 구체적 ROI를 약속합니다 (업체 상황에 따라 다를 수 있습니다)</p>
        <p class="text-xs text-gray-500 mt-1">영업시간 외 코칭 · 가게 운영에 지장 없습니다</p>
      </div>
    </div>
  </div>
</section>

<!-- ============================================ -->
<!-- 후기 섹션 -->
<!-- ============================================ -->
<section id="reviews" class="py-6 sm:py-20 bg-white" data-controller="tabs">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8 sm:mb-12" data-controller="scroll-reveal">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-4" data-scroll-reveal-target="item">수강생 후기</h2>
    </div>

    <% if @reviews.present? %>
      <!-- DB 기반 동적 후기 -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" data-controller="scroll-reveal" data-scroll-reveal-stagger-value="150">
        <% @reviews.each do |review| %>
