<div class="w-full max-w-md">
  <div class="bg-white rounded-2xl shadow-lg p-8">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-gray-900">EnterLab</h1>
      <p class="text-gray-500 mt-1">관리자 로그인</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">이메일</label>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">비밀번호</label>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center">
          <%= f.check_box :remember_me, class: "h-4 w-4 text-indigo-600 border-gray-300 rounded" %>
          <label class="ml-2 text-sm text-gray-600">로그인 유지</label>
        </div>
      <% end %>

      <% if flash[:alert] %>
        <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg text-sm">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= f.submit "로그인", class: "w-full bg-indigo-600 text-white py-3 rounded-lg font-semibold hover:bg-indigo-700 transition-colors cursor-pointer" %>
    <% end %>
  </div>
</div>
