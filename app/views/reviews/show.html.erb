<div class="min-h-screen bg-gray-100 py-12 px-4 flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-2xl shadow-xl p-8 text-center">
      <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-green-100 mb-4">
        <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-gray-900 mb-2">감사합니다!</h1>
      <p class="text-gray-500 mb-6">소중한 후기를 남겨주셔서 감사합니다.<br>관리자 승인 후 랜딩 페이지에 공개됩니다.</p>

      <% if @review.submitted? %>
        <div class="bg-gray-50 rounded-xl p-4 text-left mb-6">
          <div class="text-yellow-500 mb-2"><%= "★" * @review.rating %><%= "☆" * (5 - @review.rating) %></div>
          <p class="text-sm text-gray-700"><%= @review.content %></p>
          <p class="text-xs text-gray-400 mt-2">- <%= @review.author_name %></p>
        </div>
      <% end %>

      <%= link_to "홈으로", root_path, class: "inline-block bg-indigo-600 text-white py-3 px-6 rounded-xl font-semibold hover:bg-indigo-700 transition-all" %>
    </div>
  </div>
</div>
